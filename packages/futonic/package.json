{
  "name": "futonic",
  "version": "0.2.0",
  "description": "Embed API routes and database tables into any host application",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/isaacwasserman/futonic.git"
  },
  "homepage": "https://github.com/isaacwasserman/futonic#readme",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./client": {
      "import": "./dist/client.js",
      "types": "./dist/client.d.ts"
    },
    "./drizzle": {
      "import": "./dist/drizzle.js",
      "types": "./dist/drizzle.d.ts"
    }
  },
  "scripts": {
    "build": "bun run scripts/build.ts",
    "dev": "bun --watch src/index.ts",
    "test": "bun test",
    "typecheck": "tsgo --noEmit",
    "lint": "biome check src/",
    "format": "biome format --write src/"
  },
  "dependencies": {
    "@better-fetch/fetch": "^1.3.1",
    "@standard-community/standard-json": "^0.3.5",
    "@standard-schema/spec": "^1.1.0",
    "openapi-types": "^12.1.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/bun": "latest",
    "@typescript/native-preview": "^7.0.0-dev.20260707.2",
    "arktype": "^2.2.3",
    "better-call": "^2.0.5",
    "better-sqlite3": "^11.0.0",
    "bun-types": "^1.3.14",
    "drizzle-orm": "^0.45.2",
    "kysely": "^0.29.3",
    "typescript": "^5.7.0",
    "zod": "^4.0.0"
  },
  "peerDependencies": {
    "better-call": ">=2.0.0",
    "better-sqlite3": ">=9.0.0",
    "kysely": ">=0.29.0"
  },
  "peerDependenciesMeta": {
    "drizzle-orm": {
      "optional": true
    },
    "pg": {
      "optional": true
    },
    "mysql2": {
      "optional": true
    },
    "better-sqlite3": {
      "optional": true
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "license": "MIT"
}
